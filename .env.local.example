# Local dev uses SQLite file (data.db) — no env needed
# Production: use Turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://isitavailablein.com

# Affiliate links — fill in your tracking URL from each program's dashboard.
# Pages render fine without them (they fall back to the canonical site)
# but you earn $0 per click until they're set.
NEXT_PUBLIC_NORDVPN_AFF=
NEXT_PUBLIC_SURFSHARK_AFF=
NEXT_PUBLIC_EXPRESSVPN_AFF=
NEXT_PUBLIC_WISE_AFF=
NEXT_PUBLIC_REVOLUT_AFF=
NEXT_PUBLIC_AIRALO_AFF=
NEXT_PUBLIC_SAILY_AFF=
NEXT_PUBLIC_BINANCE_AFF=
NEXT_PUBLIC_BYBIT_AFF=

# Anti-spam salt (for hashing IPs on /api/suggest)
IP_SALT=

# Admin
ADMIN_PASSWORD=
SESSION_SECRET=

# Analytics — set in Cloudflare Pages env vars, not locally
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CF_BEACON_TOKEN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Ezoic — flip to "1" only when Ezoic approves the site
NEXT_PUBLIC_EZOIC_ENABLED=
