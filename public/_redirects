# Cloudflare Pages _redirects — 301s for legacy URLs Google still has indexed.
# Format: SOURCE  DESTINATION  STATUS

# Old icon paths that were moved to /favicon.svg
/icon.svg          /favicon.svg            301
/apple-icon.svg    /apple-touch-icon.svg   301

# Old dash-form canonical mistakenly published in our metadata.
# Wildcard catches /apps-banned-in-china → /apps-banned-in/china etc.
/apps-banned-in-:country   /apps-banned-in/:country   301

# Legacy extensioned feed URLs → real routes. next-on-pages doesn't compile
# route folders that contain dots, so the feeds live at /changes/rss and
# /changes/feed. Cloudflare Pages can't 200-rewrite onto a dynamic Function
# route (only static assets) — that's why the old 200 rewrite 404'd. Use a
# 301 redirect instead; it resolves for any reader still hitting .xml/.json.
/changes/rss.xml    /changes/rss     301
/changes/feed.json  /changes/feed    301
